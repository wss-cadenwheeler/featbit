# FeatBit API Configuration
WEST_API_BASE_URL=https://featbit-api.west.local
EAST_API_BASE_URL=https://featbit-api.east.local
LOGIN_API_BASE_URL=https://featbit-api.west.local

# Authentication
LOGIN_EMAIL=test@featbit.com
LOGIN_PASSWORD=123456
WORKSPACE_KEY=
ORGANIZATION_KEY=playground

# TLS/Certificates
SKIP_CERTIFICATE_CHECK=true

# Scenario Defaults
TIMEOUT_SECONDS=60
POLL_INTERVAL_MS=1000
DISRUPTION_HOLD_SECONDS=15

# Artifacts
ARTIFACTS_ROOT=control-plane-qa/artifacts

# Optional: API Token (if not using email/password login)
# API_AUTHORIZATION_HEADER=

# CP-08 prerequisite: the control-plane admin endpoint (X-Api-Key auth; the key
# comes from the deployment's Api__ApiKey env, "api-key" in the QA deploy).
# The URL must be host-reachable — Start-PortForwards.ps1 exposes west on
# 127.0.0.1:5200 and east on 127.0.0.1:5201. When unset, cp08 falls back to
# http://featbit-control-plane.{west|east}.local, which only resolves with the
# sudo host-nginx proxy (Setup-FeatBitProxy.ps1), not the rootless container.
# CONTROL_PLANE_BASE_URL=http://127.0.0.1:5200

# Optional: Custom Check Commands
# REDIS_WEST_CHECK_COMMAND=
# REDIS_EAST_CHECK_COMMAND=
