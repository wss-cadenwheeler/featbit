# FeatBit Deployment Configuration
#
# Copy this file to deployment.env and fill in your values.
# deployment.env is listed in .gitignore so credentials stay off disk.
#
# All values are optional — anything left blank falls back to the script default.
# Pass individual parameters on the command line to override specific values:
#
#   .\Deploy-FeatBitClusters.ps1 -WestCpus 6
#
# ─── Registry ─────────────────────────────────────────────────────────────────
#
# Registry prefix applied to all infrastructure image references that are
# rewritten from the image map (kubernetes/infra-image-map.json).
# Final image = CUSTOM_IMAGE_REGISTRY/<map path>  e.g.:
#   registry.example.com/repository/docker-proxy + mongo:7.0
#     → registry.example.com/repository/docker-proxy/mongo:7.0
# Leave blank to pull from Docker Hub directly.
#
# CUSTOM_IMAGE_REGISTRY=myregistry.example.com
# CUSTOM_IMAGE_REGISTRY=myregistry.example.com:5000

# Registry hosting the FeatBit application images (api-server, ui, evaluation-server,
# control-plane, data-analytics-server).
# Defaults to host.minikube.internal:5000 (the local Docker registry on the host).
# Set this only if your FeatBit images live on a different registry from your
# infrastructure images.
#
# FEATBIT_IMAGE_REGISTRY=registry.example.com

# Full registry path used to compute the MongoDB and PostgreSQL image references
# passed directly to `kubectl set image`. These calls bypass the image map, so
# this variable must be set explicitly whenever your proxy path does not follow
# the default /dockerhub/library convention.
#
# Default (when omitted): CUSTOM_IMAGE_REGISTRY/dockerhub/library
#
# Example — Nexus proxy:
#   CUSTOM_IMAGE_REGISTRY=registry.example.com/repository/docker-proxy
#   INFRA_IMAGE_REPOSITORY=registry.example.com/repository/docker-proxy
#     → mongo:7.0  becomes  registry.example.com/repository/docker-proxy/mongo:7.0
#
# Example — Harbor with library prefix:
#   CUSTOM_IMAGE_REGISTRY=harbor.example.com
#   INFRA_IMAGE_REPOSITORY=harbor.example.com/dockerhub/library
#
# INFRA_IMAGE_REPOSITORY=myregistry.example.com/mirror/library

# Path to the JSON file that maps Docker Hub image names to registry paths.
# Defaults to kubernetes/infra-image-map.json relative to the repo root.
# For registries with non-standard namespacing (e.g. Harbor), create
# kubernetes/infra-image-map.local.json (gitignored) with your registry paths
# and it will be merged automatically — no need to set this variable.
#
# INFRA_IMAGE_MAP_FILE=

# Credentials for CUSTOM_IMAGE_REGISTRY. When both are set, the script creates
# a docker-registry image pull secret in each cluster namespace automatically.
# Leave blank if your registry does not require authentication.
#
# CUSTOM_REGISTRY_USERNAME=myuser
# CUSTOM_REGISTRY_PASSWORD=mypassword

# Secret name created in each cluster namespace to hold the pull credentials.
# Defaults to registry-credentials.
#
# CUSTOM_REGISTRY_SECRET_NAME=registry-credentials

# ─── Images ───────────────────────────────────────────────────────────────────
#
# Override individual infra image references (full image:tag, including registry).
# Leave blank to compute automatically from CUSTOM_IMAGE_REGISTRY / INFRA_IMAGE_REPOSITORY.
#
# MONGO_IMAGE=myregistry.example.com/library/mongo:7.0
# POSTGRES_IMAGE=myregistry.example.com/library/postgres:15.10

# Custom Minikube base image. Leave blank to use the Minikube default.
#
# MINIKUBE_BASE_IMAGE=

# ─── Deployment ───────────────────────────────────────────────────────────────
#
# DeploymentMode: Basic (default) or Advanced.
#   Basic   — selected infra components run on host Docker; apps deploy to clusters.
#   Advanced — all infra runs inside both clusters.
#
# DEPLOYMENT_MODE=Basic

# DatabaseProvider: MongoDb (default) or Postgres.
#
# DATABASE_PROVIDER=MongoDb

# Comma-separated list of infra components to run on host Docker (Basic mode only).
# Valid values: redis, kafka, clickhouse, mongodb, postgresql
#
# HOST_INFRA_COMPONENTS=redis,kafka,clickhouse,mongodb

# ─── Cluster Resources ────────────────────────────────────────────────────────

# WEST_CPUS=4
# WEST_MEMORY=8192
# EAST_CPUS=4
# EAST_MEMORY=8192

# ─── Certificate Trust ────────────────────────────────────────────────────────
#
# Semicolon-separated list of corporate certificates to trust inside each
# Minikube cluster. Each entry contains three pipe-separated fields:
#   name   — short identifier used for temp-file naming
#   url    — HTTPS URL to download the PEM file from
#   target — absolute path inside the VM where the .crt file is installed
#
# Leave blank (or omit) to use the built-in defaults.
#
# TRUST_CERTIFICATES=
