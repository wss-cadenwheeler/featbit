# Deployment environment file — contains registry credentials, never commit.
# Copy deployment.env.example to deployment.env and fill in your values.
deployment.env

# Local image-map override for registry namespace customisation (e.g. Harbor).
# Copy kubernetes/infra-image-map.local.json.example to infra-image-map.local.json.
kubernetes/infra-image-map.local.json

# Generated (ephemeral) manifests produced by deployment scripts.
# These are never committed; they are produced at deploy time with
# registry-rewritten image refs and other environment-specific values.
kubernetes/.generated/

# Ignore Mac DS_Store files
.DS_Store
**/.DS_Store
/infra/mongodb/data/db/
/infra/redis/data/
benchmark/k6-scripts/test-results/

# Ignore VS Code files
.vscode/

#Ignore VS files
.vs/
/.vs/VSWorkspaceState.json
/.vs/featbit/v17/.wsuo

#Ignore dev logs
.logs/
*.log

#Ignore IntelliJ IDEA files
.idea/

# Control-plane QA local artifacts (never commit)
/control-plane-qa/deployment.env
/control-plane-qa/port-forwards.log
/control-plane-qa/windows-hyperv/.quickstart-state-hyperv.json
/control-plane-qa/Setup Challenges.txt
/build-featbit-images.ps1

# Quickstart wizard progress state files (any platform subdir: ubuntu, windows-wsl, …)
control-plane-qa/.quickstart-state-*.json
control-plane-qa/**/.quickstart-state-*.json

# otel-demo upstream source clone (fetched on demand by Build-OtelDemoImages.ps1)
control-plane-qa/01-Infrastructure/otel-demo/build/

# Automation test artifacts (scenario run outputs, timelines, assertion results)
control-plane-qa/artifacts/
control-plane-qa/01-Infrastructure/windows-hyperv/.quickstart-state-hyperv.json
