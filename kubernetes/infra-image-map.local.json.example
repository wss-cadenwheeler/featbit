{
  "description": [
    "Local override for infra-image-map.json.",
    "Values here are registry-relative paths appended to CUSTOM_IMAGE_REGISTRY.",
    "This file is gitignored — edit freely without affecting other contributors.",
    "",
    "These paths match the Harbor dockerhub-proxy namespace layout:",
    "  dockerhub/bitnamilegacy/  — Bitnami legacy images",
    "  dockerhub/library/        — Official Docker Library images",
    "  dockerhub/clickhouse/     — ClickHouse official images",
    "  dockerhub/provectuslabs/  — Provectus images"
  ],
  "images": {
    "bitnami/kafka:3.5":                  "dockerhub/bitnamilegacy/kafka:3.5",
    "bitnami/redis:6.2.10":               "dockerhub/bitnamilegacy/redis:6.2.10",
    "mongo:5.0.32":                       "dockerhub/library/mongo:5.0.32",
    "mongo:7.0":                          "dockerhub/library/mongo:7.0",
    "clickhouse/clickhouse-server:23.7":  "dockerhub/clickhouse/clickhouse-server:23.7",
    "busybox:1.28":                       "dockerhub/library/busybox:1.28",
    "provectuslabs/kafka-ui:latest":      "dockerhub/provectuslabs/kafka-ui:latest",
    "postgres:15.10":                     "dockerhub/library/postgres:15.10"
  }
}
